#!/usr/bin/env bash
set -euo pipefail

log_path="{VIETNAMESE_INPUT_LOG}"
add_ppa="{ADD_PPA}"
mkdir -p "$(dirname "$log_path")"
: >"$log_path"
exec >>"$log_path" 2>&1

echo "Checking OS..."
if command -v lsb_release >/dev/null 2>&1; then
  lsb_release -a || true
else
  cat /etc/os-release || true
fi

echo "Installing packages..."
export DEBIAN_FRONTEND=noninteractive
apt-get update

candidate="$(apt-cache policy ibus-bamboo 2>/dev/null | awk '/Candidate:/ {{print $2; exit}}' || true)"
if [ -z "$candidate" ] || [ "$candidate" = "(none)" ]; then
  if [ "$add_ppa" = "1" ]; then
    echo "ibus-bamboo is not available from current apt sources. Adding official ibus-bamboo PPA..."
    apt-get install -y software-properties-common
    add-apt-repository -y ppa:bamboo-engine/ibus-bamboo
    apt-get update
  else
    echo "ibus-bamboo is not available from current apt sources and PPA was not approved."
    exit 42
  fi
fi

apt-get install -y ibus ibus-bamboo
echo "Done"
